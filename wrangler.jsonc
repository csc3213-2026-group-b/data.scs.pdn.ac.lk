{
  "$schema": "https://www.unpkg.com/wrangler/config-schema.json",
  "name": "data-scs-pdn-ac-lk",
  "compatibility_date": "2026-07-16",
  "main": "src/index.ts",
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "data.scs-pdn.space",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./public",
    "binding": "DATA_SCS_PDN_ASSETS",
    "run_worker_first": true,
    "not_found_handling": "none"
  }
}
