{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "data.scs.pdn.ac.lk",
  "description": "Static JSON data published for SCS public sites.",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --write \"**/*.{js,ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,json,md,yml,yaml}\"",
    "test": "bun test tests",
    "typecheck": "tsc -b",
    "validate:people": "bun .github/scripts/validate-people-data.ts",
    "check": "bun run typecheck && bun run test && bun run validate:people && bun run format:check && bunx wrangler build",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "dev": "wrangler dev --local"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "none",
    "bracketSpacing": true,
    "arrowParens": "always",
    "endOfLine": "auto"
  },
  "lint-staged": {
    "*.{js,ts,json,md}": "prettier --write"
  },
  "devDependencies": {
    "@csc3213-2026-group-b/academic-domain-schemas": "^1.0.0",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@types/bun": "^1.3.14",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2",
    "wrangler": "^4.110.0",
    "zod": "^4.4.3"
  }
}
