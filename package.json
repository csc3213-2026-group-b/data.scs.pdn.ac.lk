{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "data.scs.pdn.ac.lk",
  "description": "Static JSON data published for SCS public sites.",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --write \"**/*.{js,ts,json,md}\"",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "dev": "wrangler dev --local"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "none",
    "bracketSpacing": true,
    "arrowParens": "always",
    "endOfLine": "auto"
  },
  "lint-staged": {
    "*.{js,ts,json,md}": "bunx prettier --write"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@types/bun": "^1.3.14",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "^7.0.2",
    "wrangler": "^4.108.0"
  }
}
